{
  "name": "godot-game-qa",
  "version": "1.0.0",
  "description": "Playwright + AI QA harness for Godot vampire survivors clone",
  "type": "module",
  "scripts": {
    "serve": "node server.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "ai-play": "node ai_qa.js",
    "ai-play-claude": "node ai_qa_claude.js",
    "multi-qa": "node multi_agent_qa.js",
    "multi-qa:headed": "node multi_agent_qa.js --headed",
    "multi-qa:3": "node multi_agent_qa.js --agents=3",
    "design": "node game_designer.js",
    "design:quick": "node game_designer.js --agents=3 --iterations=3 --timeout=60"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.18.2",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "playwright": "^1.44.0"
  }
}
